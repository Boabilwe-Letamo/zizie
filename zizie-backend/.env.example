# Zizie Environment Configuration
# ==================== NO API KEYS NEEDED FOR FREE TIER ====================

# ==================== SERVER ====================
DEBUG=true
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-to-random-secret-key!!

# ==================== DATABASE (Optional - uses in-memory if not set) ====================
# For Supabase: Add your project URL and key from supabase.com/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Or use local PostgreSQL:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=zizie

# ==================== FREE VOICE SERVICES (No API keys needed!) ====================

# WhisperX (FREE! Open source, runs locally)
# Install: pip install -r requirements.txt
# Requires: ffmpeg (sudo apt install ffmpeg)
USE_WHISPERX=true
WHISPERX_MODEL=base          # base, small, medium, large-v2
WHISPERX_DEVICE=cpu       # cuda or cpu (GPU recommended!)

# pyannote.audio (FREE! Speaker diarization)
USE_PYANNOTE=true
PYANNOTE_MODEL=pyannote/v3.1
# Get free HuggingFace token: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# Ollama (FREE! Local LLM)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Then run: ollama serve && ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ==================== OPTIONAL: Cloud services (only if you have API keys) ====================

# OpenAI Whisper (60min free) - only needed as fallback
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ElevenLabs (premium TTS - optional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Picovoice (optional - for wake word)
# Get key: https://picovoice.ai
PICOVOICE_API_KEY=

# ==================== GOOGLE (optional) ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==================== EMAIL (optional) ====================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=