# Database - Supabase (add your credentials)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_DB_PASSWORD=

# Server
DEBUG=true
SECRET_KEY=change-me-in-production

# Voice Services
USE_WHISPERX=true
WHISPERX_MODEL=base
WHISPERX_DEVICE=cpu
USE_PYANNOTE=true
PYANNOTE_MODEL=pyannote/v3.1

# Google OAuth (add your credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# LLM - HuggingFace (add your token)
HF_INFERENCE=false
HUGGINGFACE_TOKEN=

# Voice match
VOICE_MATCH_THRESHOLD=0.75
